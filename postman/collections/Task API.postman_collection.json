    {
      "name": "Tasks",
      "item": [
        {
          "name": "List Tasks",
          "id": "685ed22f-10e1-4b52-9a2b-f8e3ee28c293",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tasks"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "pending",
                  "description": "Filter by status: pending, in_progress, completed",
                  "disabled": true
                },
                {
                  "key": "priority",
                  "value": "high",
                  "description": "Filter by priority: low, medium, high",
                  "disabled": true
                }
              ]
            },
            "description": "Get all tasks for the authenticated user.\n\n**Query Parameters (optional):**\n- `status`: Filter by status (pending, in_progress, completed)\n- `priority`: Filter by priority (low, medium, high)\n\n**Response (200):**\n- `count`: Number of tasks returned\n- `tasks`: Array of task objects\n\n**Requires:** Bearer token authentication"
          },
          "response": []
        },
        {
          "name": "Get Task",
          "id": "bfbbb4bb-ef25-4e03-b7ff-6d05ea6fbe13",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tasks/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tasks",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "",
                  "description": "Task UUID"
                }
              ]
            },
            "description": "Get a single task by ID.\n\n**Path Parameters:**\n- `id`: Task UUID\n\n**Response (200):**\n- `task`: Task object\n\n**Errors:**\n- 404: Task not found\n\n**Requires:** Bearer token authentication"
          },
          "response": []
        },
        {
          "name": "Create Task",
          "id": "a4345311-f4c4-4f81-9e2a-4b2a37b3a452",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{tn}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": ,\n  \"description\": \"Write comprehensive API documentation\",\n  \"status\": \"pending\",\n  \"priority\": \"high\",\n  \"due_date\": \"2024-12-31\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tasks"
              ]
            },
            "description": "Create a new task.\n\n**Request Body:**\n- `title` (required): Task title\n- `description` (optional): Task description\n- `status` (optional): pending (default), in_progress, completed\n- `priority` (optional): low, medium (default), high\n- `due_date` (optional): Due date string\n\n**Response (201):**\n- `message`: Success message\n- `task`: Created task object\n\n**Errors:**\n- 400: Missing title or invalid status/priority\n\n**Requires:** Bearer token authentication"
          },
          "response": []
        },
        {
          "name": "Update Task",
          "id": "46940432-e331-432d-a7b8-c21cf994cfd6",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\",\n  \"priority\": \"medium\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tasks/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tasks",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "",
                  "description": "Task UUID"
                }
              ]
            },
            "description": "Update an existing task (partial update).\n\n**Path Parameters:**\n- `id`: Task UUID\n\n**Request Body (all optional):**\n- `title`: New task title\n- `description`: New description\n- `status`: pending, in_progress, completed\n- `priority`: low, medium, high\n- `due_date`: New due date\n\n**Response (200):**\n- `message`: Success message\n- `task`: Updated task object\n\n**Errors:**\n- 400: Invalid status/priority\n- 404: Task not found\n\n**Requires:** Bearer token authentication"
          },
          "response": []
        },
        {
          "name": "Delete Task",
          "id": "25b4b242-e4fe-4b62-87db-d79814dc044c",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tasks/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "tasks",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "",
                  "description": "Task UUID"
                }
              ]
            },
            "description": "Delete a task.\n\n**Path Parameters:**\n- `id`: Task UUID\n\n**Response (200):**\n- `message`: \"Task deleted.\"\n\n**Errors:**\n- 404: Task not found\n\n**Requires:** Bearer token authentication"
          },
          "response": []
        }
      ],
