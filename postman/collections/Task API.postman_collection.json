{
  "info": {
    "_postman_id": "d0de22df-6d69-42bd-b0f1-98b9414a8c36",
    "name": "Task API",
    "description": "A production-style REST API for managing tasks with JWT authentication.\n\n## Authentication\nMost endpoints require JWT Bearer token authentication. First use the **Signup** or **Login** endpoints to obtain a token, then set the `token` variable or include the token in the Authorization header.\n\n## Base URL\nDefault: `http://localhost:3000`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
